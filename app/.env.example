# ─────────────────────────────────────────────────────────────────────────────
# Supabase — the shared booking database + auth (Phase 1).
# Without these, the app runs as the standalone design demo on static data and
# sign-in is disabled. Set them to switch to the live Postgres backend.
# Find them in your project: Dashboard → Project Settings → API.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, bypasses RLS. Never prefix with NEXT_PUBLIC_.
# Used by trusted server paths (e.g. the WhatsApp webhook writing bookings).
SUPABASE_SERVICE_ROLE_KEY=

# Absolute site URL used for OAuth / magic-link redirects (no trailing slash).
# Vercel sets VERCEL_URL automatically; set this for a stable custom domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Phone-OTP delivery (Twilio) — configured in the Supabase dashboard, not read
# by the app directly. Listed here for the `supabase` CLI local stack only.
# WhatsApp is the primary channel; SMS is the fallback.
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGE_SERVICE_SID=

# Google OAuth (garage-owner / admin sign-in) — also set in the dashboard.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Business Cloud API — required only to send live messages / verify the
# webhook. Without these, the app runs fine and sends are no-ops (logged).
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_NUMBER=          # E.164 without '+', e.g. 254700000000

# (Future) server-side Claude call for AI-describe — keeps the key off the client.
ANTHROPIC_API_KEY=
